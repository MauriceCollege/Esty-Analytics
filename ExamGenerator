        function App() {
            const [view, setView] = useState('menu');
            const [currentChapter, setCurrentChapter] = useState(null);
            const [questionIndex, setQuestionIndex] = useState(0);
            const [score, setScore] = useState(0);
            const [wrongAnswers, setWrongAnswers] = useState([]);
            const [timeLeft, setTimeLeft] = useState(45);
            const [timerActive, setTimerActive] = useState(false);
            const [shuffledQuestions, setShuffledQuestions] = useState([]);

            const startQuiz = (chapter) => {
                let qs = [];
                if (chapter.id === 'mixed') {
                    // Collect 40 random questions from across all chapters
                    const allQs = Object.values(QUESTIONS).flat();
                    qs = [...allQs].sort(() => 0.5 - Math.random()).slice(0, 40);
                } else {
                    qs = [...QUESTIONS[chapter.id]];
                }
                
                // Final shuffle
                for (let i = qs.length - 1; i > 0; i--) {
                    const j = Math.floor(Math.random() * (i + 1));
                    [qs[i], qs[j]] = [qs[j], qs[i]];
                }
                
                setShuffledQuestions(qs);
                setCurrentChapter(chapter);
                setQuestionIndex(0);
                setScore(0);
                setWrongAnswers([]);
                setView('quiz');
                resetTimer();
            };

            const resetTimer = () => {
                setTimeLeft(45);
                setTimerActive(true);
            };

            useEffect(() => {
                let timer;
                if (timerActive && timeLeft > 0 && view === 'quiz') {
                    timer = setTimeout(() => setTimeLeft(prev => prev - 1), 1000);
                } else if (timeLeft === 0 && timerActive) {
                    handleAnswer(-1);
                }
                return () => clearTimeout(timer);
            }, [timeLeft, timerActive, view]);

            const handleAnswer = (index) => {
                setTimerActive(false);
                const currentQ = shuffledQuestions[questionIndex];
                const isCorrect = index === currentQ.answer;

                if (isCorrect) {
                    setScore(prev => prev + 1);
                } else {
                    setWrongAnswers(prev => [...prev, {
                        ...currentQ,
                        userAnswer: index,
                        timedOut: index === -1
                    }]);
                }

                setTimeout(() => {
                    if (questionIndex < shuffledQuestions.length - 1) {
                        setQuestionIndex(prev => prev + 1);
                        resetTimer();
                    } else {
                        setView('results');
                    }
                }, 600);
            };

            const renderMenu = () => (
                <div className="animate-fade-in space-y-6">
                    <header className="text-center mb-10">
                        <h1 className="text-4xl font-extrabold text-white mb-2 tracking-tight">Counseling Mastery</h1>
                        <p className="text-slate-400">180 Rosenthal-Aligned Expert Questions</p>
                    </header>
                    
                    <div className="grid grid-cols-1 md:grid-cols-2 gap-4">
                        {CHAPTERS.map(ch => (
                            <button 
                                key={ch.id}
                                onClick={() => startQuiz(ch)}
                                className="chapter-card glass-panel p-5 rounded-2xl flex items-center gap-4 text-left group"
                            >
                                <div 
                                    className="w-12 h-12 rounded-xl flex items-center justify-center shrink-0 shadow-lg"
                                    style={{ backgroundColor: ch.color }}
                                >
                                    <span className="text-white font-bold text-lg">{ch.id === 'mixed' ? '★' : ch.id.replace('ch', '')}</span>
                                </div>
                                <div>
                                    <h3 className="font-semibold text-slate-200 group-hover:text-white">{ch.title}</h3>
                                    <p className="text-xs text-slate-500 uppercase tracking-wider font-bold mt-1">
                                        {ch.id === 'mixed' ? '40 Mixed' : '20 High-Difficulty'} Questions
                                    </p>
                                </div>
                            </button>
                        ))}
                    </div>
                </div>
            );

            const renderQuiz = () => {
                const q = shuffledQuestions[questionIndex];
                const progress = ((questionIndex) / shuffledQuestions.length) * 100;
                
                return (
                    <div className="animate-fade-in space-y-6">
                        <div className="flex justify-between items-end mb-2">
                            <div className="max-w-[70%]">
                                <span className="text-xs font-bold text-indigo-400 uppercase tracking-widest block mb-1">
                                    {currentChapter.title}
                                </span>
                                <h2 className="text-slate-400 text-sm">Question {questionIndex + 1} of {shuffledQuestions.length}</h2>
                            </div>
                            <div className={`text-2xl font-mono font-bold ${timeLeft < 10 ? 'text-red-500 animate-pulse' : 'text-slate-300'}`}>
                                {timeLeft}s
                            </div>
                        </div>

                        <div className="w-full h-2 bg-slate-800 rounded-full overflow-hidden mb-8">
                            <div 
                                className="h-full bg-indigo-500 progress-bar" 
                                style={{ width: `${progress}%` }}
                            ></div>
                        </div>

                        <div className="glass-panel p-8 rounded-3xl mb-6 min-h-[160px] flex items-center">
                            <h3 className="text-xl md:text-2xl font-medium leading-relaxed text-white">
                                {q.q}
                            </h3>
                        </div>

                        <div className="grid grid-cols-1 gap-3">
                            {q.options.map((opt, i) => (
                                <button
                                    key={i}
                                    onClick={() => handleAnswer(i)}
                                    className="option-btn glass-panel p-5 rounded-xl text-left hover:border-indigo-500/50 flex gap-4 items-center group"
                                >
                                    <span className="w-8 h-8 rounded-lg bg-slate-700 flex items-center justify-center shrink-0 group-hover:bg-indigo-600 transition-colors">
                                        {String.fromCharCode(65 + i)}
                                    </span>
                                    <span className="text-slate-300 group-hover:text-white transition-colors">{opt}</span>
                                </button>
                            ))}
                        </div>
                    </div>
                );
            };

            const renderResults = () => {
                const percentage = Math.round((score / shuffledQuestions.length) * 100);
                const isPass = percentage >= 75;

                return (
                    <div className="animate-fade-in space-y-8 pb-10">
                        <div className="glass-panel p-10 rounded-3xl text-center">
                            <div className={`text-6xl font-black mb-4 ${isPass ? 'text-emerald-400' : 'text-orange-400'}`}>
                                {percentage}%
                            </div>
                            <h2 className="text-2xl font-bold text-white mb-2">
                                {isPass ? "NCE Mastery Level!" : "Keep Studying..."}
                            </h2>
                            <p className="text-slate-400 mb-8">
                                You scored {score} out of {shuffledQuestions.length}.
                            </p>
                            <button 
                                onClick={() => setView('menu')}
                                className="bg-indigo-600 hover:bg-indigo-700 text-white px-8 py-3 rounded-full font-bold transition-all shadow-lg shadow-indigo-500/20"
                            >
                                Practice More Chapters
                            </button>
                        </div>

                        {wrongAnswers.length > 0 && (
                            <div className="space-y-4">
                                <h3 className="text-lg font-bold text-slate-300 flex items-center gap-2">
                                    <span className="w-2 h-6 bg-red-500 rounded-full"></span>
                                    Review Critical Gaps
                                </h3>
                                {wrongAnswers.map((w, i) => (
                                    <div key={i} className="glass-panel p-6 rounded-2xl border-l-4 border-red-500/50">
                                        <div className="text-white font-semibold mb-3 leading-snug">{w.q}</div>
                                        <div className="space-y-2 mb-4">
                                            {w.timedOut ? (
                                                <div className="text-sm text-orange-400 font-medium">⏰ Time Limit Reached</div>
                                            ) : (
                                                <div className="text-sm text-red-400">❌ Your Choice: <span className="font-bold">{w.options[w.userAnswer]}</span></div>
                                            )}
                                            <div className="text-sm text-emerald-400">✅ Correct: <span className="font-bold">{w.options[w.answer]}</span></div>
                                        </div>
                                        <div className="bg-slate-900/50 p-4 rounded-xl text-sm leading-relaxed text-slate-400 border border-slate-800">
                                            <div className="text-xs font-bold text-indigo-400 uppercase mb-1 tracking-wider">Expert Analysis (Page {w.page})</div>
                                            {w.explanation}
                                        </div>
                                    </div>
                                ))}
                            </div>
                        )}
                    </div>
                );
            };

            return (
                <main className="w-full">
                    {view === 'menu' && renderMenu()}
                    {view === 'quiz' && renderQuiz()}
                    {view === 'results' && renderResults()}
                </main>
            );
        }

        const root = ReactDOM.createRoot(document.getElementById('app'));
        root.render(<App />);
    </script>
</body>
</html>
