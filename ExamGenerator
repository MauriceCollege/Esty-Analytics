            ch6: [
                { q: "According to Irvin Yalom, the 'curative factor' that involves realizing others share similar problems is called:", options: ["Altruism", "Universality", "Cohesiveness", "Catharsis"], answer: 1, page: 204, explanation: "Universality helps group members feel less isolated and 'broken'." },
